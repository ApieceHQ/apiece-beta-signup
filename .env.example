# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# The deployed Google Apps Script web app URL (ends in /exec).
# This script appends the application to your Google Sheet AND emails dp@apiece.co.
APPS_SCRIPT_URL=

# A shared secret. Set the SAME value here and as APPLY_SECRET in the Apps Script
# (Project Settings → Script properties). The server route sends it so the script
# can reject random POSTs from the public internet.
APPS_SCRIPT_SECRET=

# Production site URL, used to make OG/social image links absolute (e.g. https://apiece.co).
# Optional locally. On Vercel, the deployment URL is used automatically if this is unset.
NEXT_PUBLIC_SITE_URL=
